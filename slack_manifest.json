{
    "display_information": {
        "name": "Demo App"
    },
    "features": {
        "bot_user": {
            "display_name": "Demo App",
            "always_online": true
        }
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "chat:write",
                "app_mentions:read"
            ]
        }
    },
    "settings": {
        "event_subscriptions": {
            "request_url": "https://unsuited-premiere-tray.ngrok-free.dev/api/slack/events/",
            "bot_events": [
                "app_mention"
            ]
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": false,
        "is_hosted": false,
        "token_rotation_enabled": false
    }
}
